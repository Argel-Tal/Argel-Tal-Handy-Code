    "expressions": [
      {
        "name": "API prices",
        "annotations": [
          {
            "name": "PBI_NavigationStepName",
            "value": "Navigation"
          },
          {
            "name": "PBI_ResultType",
            "value": "Table"
          }
        ],
        "description": [
          "Code snippet from Ali Harrison",
          "Prices are per CU",
          "Requires internet connection & HMTL read to refresh - would need a VM with webclient enabled to enable auto-refresh"
        ],
        "expression": [
          "let",
          "    api_filter = \"/?currencyCode='\" & currency & \"'&$filter=armRegionName eq '\" & region & \"' and serviceName eq 'Microsoft Fabric' and armSkuName eq 'Fabric_Capacity_CU_Hour'\",",
          "    Source = Json.Document(Web.Contents(azure_price_api_base_url & api_filter)),",
          "    #\"Converted to Table\" = Table.FromRecords({Source}),",
          "    #\"Expanded Items\" = Table.ExpandListColumn(#\"Converted to Table\", \"Items\"),",
          "    #\"Expanded Items1\" = Table.ExpandRecordColumn(#\"Expanded Items\", \"Items\", {\"currencyCode\", \"tierMinimumUnits\", \"reservationTerm\", \"retailPrice\", \"unitPrice\", \"armRegionName\", \"location\", \"effectiveStartDate\", \"meterId\", \"meterName\", \"productId\", \"skuId\", \"productName\", \"skuName\", \"serviceName\", \"serviceId\", \"serviceFamily\", \"unitOfMeasure\", \"type\", \"isPrimaryMeterRegion\", \"armSkuName\"}, {\"Items.currencyCode\", \"Items.tierMinimumUnits\", \"Items.reservationTerm\", \"Items.retailPrice\", \"Items.unitPrice\", \"Items.armRegionName\", \"Items.location\", \"Items.effectiveStartDate\", \"Items.meterId\", \"Items.meterName\", \"Items.productId\", \"Items.skuId\", \"Items.productName\", \"Items.skuName\", \"Items.serviceName\", \"Items.serviceId\", \"Items.serviceFamily\", \"Items.unitOfMeasure\", \"Items.type\", \"Items.isPrimaryMeterRegion\", \"Items.armSkuName\"}),",
          "    #\"Changed Type\" = Table.TransformColumnTypes(#\"Expanded Items1\",{{\"BillingCurrency\", type text}, {\"CustomerEntityId\", type text}, {\"CustomerEntityType\", type text}, {\"Items.currencyCode\", type text}, {\"Items.tierMinimumUnits\", Int64.Type}, {\"Items.reservationTerm\", type text}, {\"Items.retailPrice\", type number}, {\"Items.unitPrice\", type number}, {\"Items.armRegionName\", type text}, {\"Items.location\", type text}, {\"Items.effectiveStartDate\", type datetime}, {\"Items.meterId\", type text}, {\"Items.meterName\", type text}, {\"Items.productId\", type text}, {\"Items.skuId\", type text}, {\"Items.productName\", type text}, {\"Items.skuName\", type text}, {\"Items.serviceName\", type text}, {\"Items.serviceId\", type text}, {\"Items.serviceFamily\", type text}, {\"Items.unitOfMeasure\", type text}, {\"Items.type\", type text}, {\"Items.isPrimaryMeterRegion\", type logical}, {\"Items.armSkuName\", type text}, {\"NextPageLink\", type any}, {\"Count\", Int64.Type}}),",
          "    #\"Removed Other Columns\" = Table.SelectColumns(#\"Changed Type\",{\"Items.type\", \"Items.productName\", \"Items.unitPrice\", \"Items.reservationTerm\"}),",
          "    #\"Renamed Columns\" = Table.RenameColumns(#\"Removed Other Columns\",{{\"Items.type\", \"type\"}, {\"Items.productName\", \"product_name\"}, {\"Items.unitPrice\", \"unit_price\"}, {\"Items.reservationTerm\", \"reservation_term\"}}),",
          "    #\"Added mode\" = Table.AddColumn(#\"Renamed Columns\", \"Payment Type\", each if [type] = \"Consumption\" then \"Pay-as-you-go\" else if [type] = \"Reservation\" then \"Reservation\" else [type]),",
          "    #\"Added hourly_price\" = Table.AddColumn(#\"Added mode\", \"hourly_price\", each if [reservation_term] = \"1 Year\" then [unit_price] / 365 / 24 else [unit_price], type number),",
          "    // ratio of hourly price to monthly price gives 729.999...",
          "    #\"Added monthly_price\" = Table.AddColumn(#\"Added hourly_price\", \"monthly_price\", each 730 * [hourly_price])",
          "in",
          "    #\"Added monthly_price\""
        ],
        "kind": "m",
        "lineageTag": "e64bd9a0-6a5d-42fe-9bc1-5884aaf08e80",
        "queryGroup": "01 Stg"
      },
