        "partitions": [
          {
            "name": "User license range",
            "mode": "import",
            "queryGroup": "02 Model Tbs",
            "source": {
              "expression": [
                "let",
                "    Source = List.Numbers(0,71,10),",
                "    #\"Converted to Table\" = Table.FromList(Source, Splitter.SplitByNothing(), null, null, ExtraValues.Error),",
                "    #\"Changed to numbers\" = Table.TransformColumnTypes(#\"Converted to Table\",{{\"Column1\", Int64.Type}}),",
                "    #\"Renamed Columns\" = Table.RenameColumns(#\"Changed to numbers\",{{\"Column1\", \"Number Licenses\"}})",
                "in",
                "    #\"Renamed Columns\""
              ],
              "type": "m"
            }
          }
        ]
      },
      {
        "name": "MeasuresTb",
        "annotations": [
          {
            "name": "PBI_ResultType",
            "value": "Table"
          },
          {
            "name": "PBI_NavigationStepName",
            "value": "Navigation"
          }
        ],
        "lineageTag": "1a002336-b94b-4e36-b5c0-033b0edf0b14",
        "measures": [
          {
            "name": "Additional Users",
            "expression": "SELECTEDVALUE('User license range'[Number Licenses])",
            "formatString": "0",
            "lineageTag": "9b023907-aa20-4e5c-907e-cc493e7fdbe7"
          },
          {
            "name": "LicensingCost",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": "SELECTEDVALUE('License Prices'[Cost]) * MAX('User license range'[Number Licenses])",
            "lineageTag": "56de21c5-dcda-414f-af44-ad5c9df0d1ca"
          },
          {
            "name": "F64",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": [
              "CALCULATE(",
              "    MAX('F64baseline'[Monthly Price])",
              ")"
            ],
            "lineageTag": "103b02d6-715b-48e3-9d23-ebc1e857debe"
          },
          {
            "name": "Capacity Cost",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"currencyCulture\":\"en-AU\"}"
              }
            ],
            "expression": [
              "",
              "    VAR activePerc = If([SelectedMode] <> \"Reservation\", 'Up time'[Up time Value], 1)",
              "    VAR cost = CALCULATE(",
              "        MAX('SKU prices'[Monthly Price])",
              "        , FILTER('SKU prices'",
              "            , 'SKU prices'[SKU] = SELECTEDVALUE('SKU prices'[SKU])",
              "        )",
              "    )",
              "    RETURN cost * activePerc"
            ],
            "formatString": "\\$#,0.00;-\\$#,0.00;\\$#,0.00",
            "lineageTag": "e87a82fb-5f83-4a87-bf35-f4cd771210a9"
          },
          {
            "name": "TotalCost",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"currencyCulture\":\"en-AU\"}"
              }
            ],
            "expression": "[LicensingCost] + [Capacity Cost]",
            "formatString": "\\$#,0.00;-\\$#,0.00;\\$#,0.00",
            "lineageTag": "79bffc1c-6906-48c7-88ad-b486ea3c7903"
          },
          {
            "name": "Breakeven",
            "expression": [
              "",
              "var BreakEvenCount = ([F64] - [Capacity Cost]) / SELECTEDVALUE('License Prices'[Cost])",
              "var ReturnObj = IF(BreakEvenCount > 0, BreakEvenCount, 0)",
              "",
              "RETURN ROUNDUP(ReturnObj, 0)"
            ],
            "formatString": "0",
            "lineageTag": "b236ec3a-9527-4eb5-b7c6-b43616087f9d"
          },
          {
            "name": "ReservedCost",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"currencyCulture\":\"en-AU\"}"
              }
            ],
            "expression": [
              "CALCULATE(",
              "        MAX('SKU prices'[Monthly Price])",
              "        , 'SKU prices'[SKU] = SELECTEDVALUE('SKU prices'[SKU])",
              "        , 'SKU prices'[Mode] = \"Reservation\"",
              "    )"
            ],
            "formatString": "\\$#,0.00;-\\$#,0.00;\\$#,0.00",
            "lineageTag": "c335da40-8f4e-492c-912e-d4af2d5e7028"
          },
          {
            "name": "PAYG saving",
            "expression": [
              "",
              "    VAR divsionValue = DIVIDE([Capacity Cost], [ReservedCost], 0)",
              "    VAR noSavingCheck = divsionValue >= 1",
              "    VAR returnObj = IF(noSavingCheck, (1-divsionValue), divsionValue)",
              "RETURN returnObj"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "lineageTag": "0f9e0f3e-15ef-4bed-9e68-cedd8dba3185"
          },
          {
            "name": "SavingColour",
            "expression": [
              "//IF([PAYG saving] > 0, \"#77bf62\", \"#c84547\")",
              "SWITCH(TRUE",
              "    , [PAYG saving] > 0, \"#77bf62\"",
              "    , [PAYG saving] = 0, \"#edb938\"",
              "    , [PAYG saving] < 0, \"#c84547\"",
              ")"
            ],
            "lineageTag": "737db013-2ec0-4409-93b0-af3d527fad00"
          },
          {
            "name": "SelectedMode",
            "expression": "SELECTEDVALUE('SKU prices'[Mode])",
            "lineageTag": "c24c7d77-3f7a-4b31-b580-aefe1f918ed0"
          }
        ],
        "partitions": [
          {
            "name": "MeasuresTb",
            "mode": "import",
            "queryGroup": "00 Utils",
            "source": {
              "expression": [
                "let",
                "    Source = Table.FromRows(Json.Document(Binary.Decompress(Binary.FromText(\"i44FAA==\", BinaryEncoding.Base64), Compression.Deflate)), let _t = ((type nullable text) meta [Serialized.Text = true]) in type table [Column1 = _t]),",
                "    #\"Changed Type\" = Table.TransformColumnTypes(Source,{{\"Column1\", type text}}),",
                "    #\"Removed Columns\" = Table.RemoveColumns(#\"Changed Type\",{\"Column1\"})",
                "in",
                "    #\"Removed Columns\""
              ],
              "type": "m"
            }
          }
        ]
      },
