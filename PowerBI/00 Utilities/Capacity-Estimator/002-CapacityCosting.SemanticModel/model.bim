            "lineageTag": "3db1e202-b0f1-4468-bdae-ae72e6fecc20",
            "sortByColumn": "Cost",
            "sourceColumn": "License Type",
            "summarizeBy": "none"
          },
          {
            "name": "Cost",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "User"
              },
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "dataType": "double",
            "lineageTag": "96eaecda-2860-47fb-8931-0d5700c3f93a",
            "sourceColumn": "Cost",
            "summarizeBy": "none"
          }
        ],
        "lineageTag": "4c16ba77-31ab-495f-8b82-677595d530d1",
        "partitions": [
          {
            "name": "License Prices",
            "mode": "import",
            "queryGroup": "02 Model Tbs",
            "source": {
              "expression": [
                "let",
                "    Source = Web.BrowserContents(\"https://www.microsoft.com/en-au/power-platform/products/power-bi/pricing#tabs-pill-bar-ocbbe94_tab1\" & \"/html/body/div[1]/div[3]/div/div[2]/main/div/div/div/div[3]/div[2]/div[1]/div/div[2]/div/div[1]/div/div[2]/div/div/div[1]/div/div/div/div[2]/div/div[2]/div/div/div[3]/div[2]/span\"),",
                "    #\"Extracted Table From Html\" = Html.Table(Source, {{\"Column1\", \".container .oc-displayListPrice\"}, {\"Column2\", \".section-master\\-\\-breadth-comfortable .base DIV\"}, {\"Column3\", \".bg\\-\\-card-normal H3\"}, {\"Column4\", \".layout .btn\\-\\-md:nth-child(1) *\"}}, [RowSelector=\".sku-cards__card\"]),",
                "    #\"Changed Type\" = Table.TransformColumnTypes(#\"Extracted Table From Html\",{{\"Column1\", type text}, {\"Column2\", type text}, {\"Column3\", type text}, {\"Column4\", type text}}),",
                "    #\"Removed Other Columns\" = Table.SelectColumns(#\"Changed Type\",{\"Column3\", \"Column1\"}),",
                "    #\"Renamed Columns\" = Table.RenameColumns(#\"Removed Other Columns\",{{\"Column3\", \"License Type\"}, {\"Column1\", \"Cost\"}}),",
                "    #\"Filtered to per user\" = Table.SelectRows(#\"Renamed Columns\", each ([License Type] = \"Free account\" or [License Type] = \"Power BI Premium Per User\" or [License Type] = \"Power BI Pro\")),",
                "    #\"Extracted price\" = Table.TransformColumns(#\"Filtered to per user\", {{\"Cost\", each Text.AfterDelimiter(_, \"AU$\"), type text}}),",
                "    #\"Replaced blank w 0\" = Table.ReplaceValue(#\"Extracted price\",\"\",\"0\",Replacer.ReplaceValue,{\"Cost\"}),",
                "    #\"Changed price to number\" = Table.TransformColumnTypes(#\"Replaced blank w 0\",{{\"Cost\", type number}}),",
                "    #\"Removed Duplicates\" = Table.Distinct(#\"Changed price to number\", {\"License Type\"})",
                "in",
                "    #\"Removed Duplicates\""
              ],
              "type": "m"
            }
          }
        ]
      },
      {
