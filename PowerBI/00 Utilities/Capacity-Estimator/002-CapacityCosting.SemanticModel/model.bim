        "description": "Prices are returned for default: Region = US Central, Currency = USD",
        "lineageTag": "61d245f2-1766-4d9d-b4cd-e52be49e07d0",
        "partitions": [
          {
            "name": "SKU prices",
            "mode": "import",
            "queryGroup": "02 Model Tbs",
            "source": {
              "expression": [
                "let",
                "    Source = Web.BrowserContents(\"https://azure.microsoft.com/en-au/pricing/details/microsoft-fabric/?culture=en-au&country=au\" & \"/html/body/main/section[3]/div[1]/div/div/div[2]/table/tbody/tr[1]\"),",
                "    #\"Extracted Table From Html\" = Html.Table(Source, {{\"Column1\", \"DIV.row.row-size3.column:nth-child(6) > DIV.data-table__shadow-wrapper > DIV.data-table-base.data-table\\-\\-pricing > TABLE.data-table__table.data-table__table\\-\\-pricing > * > TR > :nth-child(1)\"}, {\"Column2\", \"DIV.row.row-size3.column:nth-child(6) > DIV.data-table__shadow-wrapper > DIV.data-table-base.data-table\\-\\-pricing > TABLE.data-table__table.data-table__table\\-\\-pricing > * > TR > :nth-child(2)\"}, {\"Column3\", \"DIV.row.row-size3.column:nth-child(6) > DIV.data-table__shadow-wrapper > DIV.data-table-base.data-table\\-\\-pricing > TABLE.data-table__table.data-table__table\\-\\-pricing > * > TR > :nth-child(3)\"}, {\"Column4\", \"DIV.row.row-size3.column:nth-child(6) > DIV.data-table__shadow-wrapper > DIV.data-table-base.data-table\\-\\-pricing > TABLE.data-table__table.data-table__table\\-\\-pricing > * > TR > :nth-child(4)\"}}, [RowSelector=\"DIV.row.row-size3.column:nth-child(6) > DIV.data-table__shadow-wrapper > DIV.data-table-base.data-table\\-\\-pricing > TABLE.data-table__table.data-table__table\\-\\-pricing > * > TR\"]),",
                "    #\"Promoted Headers\" = Table.PromoteHeaders(#\"Extracted Table From Html\", [PromoteAllScalars=true]),",
                "    #\"Filtered to F SKUs\" = Table.SelectRows(#\"Promoted Headers\", each Text.StartsWith([SKU], \"F\")),",
                "    #\"Changed Type\" = Table.TransformColumnTypes(#\"Filtered to F SKUs\",{{\"SKU\", type text}, {\"Capacity unit (CU)\", Int64.Type}, {\"Pay-as-you-go\", type text}, {\"Reservation\", type text}}),",
                "    #\"extracted PAYG price\" = Table.TransformColumns(#\"Changed Type\", {{\"Pay-as-you-go\", each Text.BetweenDelimiters(_, \"$\", \"/\"), type text}}),",
                "    #\"extracted reserved price\" = Table.TransformColumns(#\"extracted PAYG price\", {{\"Reservation\", each Text.BetweenDelimiters(_, \"$\", \"/\"), type text}}),",
                "    #\"Unpivoted Other Columns\" = Table.UnpivotOtherColumns(#\"extracted reserved price\", {\"SKU\", \"Capacity unit (CU)\"}, \"Mode\", \"Price\"),",
                "    #\"Removed Other Columns\" = Table.SelectColumns(#\"Unpivoted Other Columns\",{\"SKU\", \"Capacity unit (CU)\", \"Mode\"}),",
                "    #\"Merged Queries\" = Table.NestedJoin(#\"Removed Other Columns\", {\"Mode\"}, #\"API prices\", {\"Payment Type\"}, \"API prices\", JoinKind.LeftOuter),",
                "    #\"Expanded API prices\" = Table.ExpandTableColumn(#\"Merged Queries\", \"API prices\", {\"hourly_price\", \"monthly_price\"}, {\"API prices.hourly_price\", \"API prices.monthly_price\"}),",
                "    #\"Added Hourly price\" = Table.AddColumn(#\"Expanded API prices\", \"Hourly Price\", each [#\"Capacity unit (CU)\"] * [API prices.hourly_price], type number),",
                "    #\"Added Monthly price\" = Table.AddColumn(#\"Added Hourly price\", \"Monthly Price\", each [#\"Capacity unit (CU)\"] * [API prices.monthly_price], type number),",
                "    #\"Removed Columns\" = Table.RemoveColumns(#\"Added Monthly price\",{\"API prices.hourly_price\", \"API prices.monthly_price\"})",
                "in",
                "    #\"Removed Columns\""
              ],
              "type": "m"
            }
          }
        ]
      }
    ]
